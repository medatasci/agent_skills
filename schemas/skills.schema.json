{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/skills.schema.json",
  "title": "SkillForge Catalog",
  "type": "object",
  "required": [
    "schema_version",
    "marketplace",
    "generated_at",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "marketplace": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "owner",
          "tags",
          "source",
          "catalog_path",
          "updated_at",
          "checksum",
          "codex",
          "warnings"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "short_description": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk_level": {
            "type": "string"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "homepage_path": {
            "type": "string"
          }
        }
      }
    }
  }
}

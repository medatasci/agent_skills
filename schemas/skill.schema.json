{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/skill.schema.json",
  "title": "SkillForge Skill Metadata",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "description",
    "owner",
    "tags",
    "source",
    "catalog_path",
    "updated_at",
    "checksum",
    "codex",
    "files",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "short_description": {
      "type": "string"
    },
    "expanded_description": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "use_when": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "do_not_use_when": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_level": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "page_title": {
      "type": "string"
    },
    "meta_description": {
      "type": "string"
    },
    "homepage_path": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "object",
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "catalog_path": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "checksum": {
      "type": "object",
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "codex": {
      "type": "object",
      "required": [
        "install_scopes",
        "global_install_command",
        "project_install_command"
      ],
      "properties": {
        "install_scopes": {
          "type": "array",
          "items": {
            "enum": [
              "global",
              "project"
            ]
          }
        },
        "global_install_command": {
          "type": "string"
        },
        "project_install_command": {
          "type": "string"
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "bytes",
          "sha256"
        ]
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

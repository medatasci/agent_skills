{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/search-index.schema.json",
  "title": "SkillForge Search Index",
  "type": "object",
  "required": [
    "schema_version",
    "marketplace",
    "generated_at",
    "fields_indexed",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "marketplace": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "fields_indexed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "search_text",
          "source",
          "checksum",
          "codex"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "short_description": {
            "type": "string"
          },
          "expanded_description": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "use_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "do_not_use_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "page_title": {
            "type": [
              "string",
              "null"
            ]
          },
          "meta_description": {
            "type": [
              "string",
              "null"
            ]
          },
          "homepage_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "homepage_text": {
            "type": "string"
          },
          "search_text": {
            "type": "string"
          },
          "source_catalog": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "trust_notes": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
